# ── Server ─────────────────────────────────────────────
PORT=8080
APP_URL=http://localhost:8080
ADMIN_APP_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── MongoDB ────────────────────────────────────────────
# Must be a replica set for transactions (admin invite claim).
MONGO_URI=mongodb://mongo:27017/?replicaSet=rs0&directConnection=true
MONGO_DB_NAME=restaurantsaas

# ── Redis (optional) ───────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ───────────────────────────────────────────────
JWT_SECRET=change-me-in-prod-min-32-chars
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Bootstrap the first admin of an existing restaurant by slug + invite code.
# When set, POST /api/auth/admin/finalize {"invite_code":"<ADMIN_LEGACY_INVITE_CODE>"}
# attaches the signed-in user to the restaurant with id ADMIN_LEGACY_RESTAURANT_ID
# as a regular admin. Unset both after bootstrap.
ADMIN_LEGACY_INVITE_CODE=
ADMIN_LEGACY_RESTAURANT_ID=

# ── Stripe (test mode) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── AWS S3 ─────────────────────────────────────────────
AWS_S3_BUCKET=auragouploader
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
S3_PUBLIC_BASE_URL=https://auragouploader.s3.us-east-1.amazonaws.com

# ── AI / LLM (optional) ────────────────────────────────
# When LLM_API_KEY is unset:
#   - POST /api/ai/search uses a rule-based intent parser
#   - POST /api/ai/chat returns HTTP 200 with a deterministic fallback reply
# Provider: "anthropic" (default) or "openai" (use LLM_BASE_URL to point the
# OpenAI adapter at a compatible provider like Groq / Together AI).
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# ── OpenSearch (reserved, optional) ────────────────────
# Currently unused — discovery falls back to Mongo aggregation.
OPENSEARCH_URL=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
